import { VerticalBox, HorizontalBox, Button, LineEdit } from "std-widgets.slint";

export component NewNetwork inherits PopupWindow {
    callback create(string);

    close-policy: no-auto-close;
    width: 320px;
    height: 220px;

    Rectangle {
        background: @linear-gradient(180deg, #3a3a3a 0%, #2b2b2b 100%);
        border-radius: 8px;
        border-color: #555;
        border-width: 1px;
        
        // Drop shadow effect
        drop-shadow-blur: 10px;
        drop-shadow-color: black;

        VerticalBox {
            padding: 16px;
            spacing: 12px;

            Text {
                text: "Create New Network";
                font-size: 16px;
                font-weight: 700;
            }

            name-input := LineEdit {
                placeholder-text: "Network Name (e.g. My Neural Net)";
            }

            LineEdit {
                placeholder-text: "Hidden Layers Structure (e.g. 128, 64, 32)";
            }

            Rectangle { vertical-stretch: 1; } // Spacer

            HorizontalBox {
                alignment: end;
                Button {
                    text: "Cancel";
                    clicked => { root.close(); }
                }
                Button {
                    text: "Create";
                    primary: true;
                    clicked => { root.create(name-input.text); }
                }
            }
        }
    }
}